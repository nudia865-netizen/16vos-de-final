<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Prode – 16avos Mundial 2026</title>

<style>
.flag img {
  width: 18px;
  height: 12px;
  object-fit: cover;
  border-radius: 2px;
}
</style>

</head>
<body>

<div id="matchesContainer"></div>

<script>
// FLAGS como códigos (NO emojis)
const FLAGS = {
  'Sudáfrica': 'za',
  'Canadá': 'ca',
  'Brasil': 'br',
  'Japón': 'jp',
  'Alemania': 'de',
  'Países Bajos': 'nl',
  'Marruecos': 'ma',
  'Costa de Marfil': 'ci',
  'México': 'mx',
  'Suiza': 'ch',
  'Estados Unidos': 'us',
  'Bosnia y Herzegovina': 'ba',
  'Australia': 'au',
  'Argentina': 'ar',
  'Suecia': 'se',
  'Francia': 'fr',
  'España': 'es',
  'Portugal': 'pt',
  'Inglaterra': 'gb',
  'Colombia': 'co'
};

const PARTIDOS = [
  { local: 'Argentina', visitante: 'Brasil' },
  { local: 'Alemania', visitante: 'Francia' },
  { local: 'España', visitante: 'Portugal' }
];

const container = document.getElementById('matchesContainer');

PARTIDOS.forEach(p => {
  const localFlag = FLAGS[p.local];
  const visitFlag = FLAGS[p.visitante];

  const row = document.createElement('div');

  row.innerHTML = `
    <div>
      <span class="flag">
        <img src="https://flagcdn.com/w20/${localFlag}.png">
      </span>
      ${p.local}
      vs
      ${p.visitante}
      <span class="flag">
        <img src="https://flagcdn.com/w20/${visitFlag}.png">
      </span>
    </div>
  `;

  container.appendChild(row);
});
</script>

</body>
</html>
